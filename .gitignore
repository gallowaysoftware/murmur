# Binaries
*.exe
*.dll
*.so
*.dylib
/bin/
/dist/

# Test artifacts
*.test
*.out
coverage.txt
coverage.html

# Editor / OS
.idea/
.vscode/
.DS_Store
*.swp

# Go workspace — go.work is COMMITTED so the multi-module structure
# (root + pkg/exec/batch/sparkconnect submodule) composes the same way
# in CI as in local dev. go.work.sum is the workspace-level cache and
# stays out of version control.
go.work.sum

# Local dev
.env
.envrc
*.local.yml
*.local.yaml

# Built UI artifacts — produced by `make web-build` (or `npm run build` in web/),
# then copied into pkg/admin/dist for embed.FS. Don't track them.
/web/dist/
/pkg/admin/dist/

# Generated TypeScript bindings — produced by `make web-proto` (or
# `npx buf generate` in web/). The Go bindings under proto/gen/ are checked
# in (Go is more sensitive to module-path drift), but TS is regenerated.
/web/src/gen/

# Terraform working directories and state. The .terraform/ cache and
# .tfstate files are local to a working copy; the modules under
# deploy/terraform/ are root-less (consumers compose them), so lock files
# at the module level would just create churn.
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
